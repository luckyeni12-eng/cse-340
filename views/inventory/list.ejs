<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles/main.css">

    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }

        nav ul {
            display: flex;
            gap: 15px;
            list-style: none;
            padding: 0;
        }

        nav a {
            text-decoration: none;
            padding: 8px 12px;
            background: #333;
            color: #fff;
            border-radius: 5px;
        }

        nav a:hover {
            background: #555;
        }

        .inventory-container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }

        .vehicle-card {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 10px;
            width: 300px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .vehicle-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 10px;
        }

        .vehicle-info {
            margin-top: 10px;
        }

        .vehicle-info h2 {
            margin: 5px 0;
            font-size: 1.2em;
        }

        .vehicle-info p {
            margin: 3px 0;
        }

        .price {
            font-weight: bold;
            color: green;
        }
    </style>
</head>

<body>

    <!-- ✅ FIXED NAVIGATION -->
    <nav>
        <ul>
            <li>
                <a href="/inv/type/all">All</a>
            </li>

            <% classifications.forEach(c => { %>
                <li>
                    <a href="/inv/type/<%= c.classification_name %>">
                        <%= c.classification_name %>
                    </a>
                </li>
            <% }) %>
        </ul>
    </nav>

    <h1><%= title %></h1>

    <div class="inventory-container">
        <% if (data && data.length > 0) { %>

            <% data.forEach(vehicle => { %>

                <div class="vehicle-card">

                    <!-- ✅ IMAGE FIX -->
                    <img 
                        src="<%= vehicle.inv_image ? vehicle.inv_image : '/images/vehicles/no-image.png' %>" 
                        alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>"
                    >

                    <div class="vehicle-info">
                        <h2>
                            <%= vehicle.inv_make %> <%= vehicle.inv_model %>
                        </h2>

                        <p class="price">
                            $<%= Number(vehicle.inv_price).toLocaleString() %>
                        </p>

                        <p>
                            Mileage: <%= vehicle.inv_mileage || 'N/A' %> miles
                        </p>

                        <% if (vehicle.description) { %>
                            <p><%= vehicle.description %></p>
                        <% } %>

                    </div>

                </div>

            <% }) %>

        <% } else { %>

            <p>No vehicles found in this classification.</p>

        <% } %>
    </div>

</body>
</html>