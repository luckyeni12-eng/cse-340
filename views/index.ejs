<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CSE Motors | Home</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <section class="hero">
    <h2>Welcome to CSE Motors</h2>

    <div class="hero-content">

      <div class="hero-text">
        <h3>2024 Lamborghini Aventador</h3>
        <ul>
          <li>Powerful V12 Engine</li>
          <li>Advanced Aerodynamics</li>
          <li>Luxury Performance Interior</li>
          <li>Unmatched Speed</li>
        </ul>
        <button aria-label="Own the 2024 Lamborghini Aventador today">
          Own Today
        </button>
      </div>

      <img 
        src="/images/vehicles/adventador.jpg" 
        alt="Red Lamborghini Aventador sports car"
      >

    </div>
  </section>

  <section class="home-sections">

    <div class="upgrades">
      <h2>Vehicle Upgrades</h2>

      <div class="upgrade-grid">

        <div class="upgrade-item">
          <img src="/images/vehicles/fire-truck.jpg" alt="Fire truck upgrade kit">
          <p>Fire Truck Kit</p>
        </div>

        <div class="upgrade-item">
          <img src="/images/vehicles/hummer.jpg" alt="Hummer offroad upgrade package">
          <p>Hummer Offroad Package</p>
        </div>

        <div class="upgrade-item">
          <img src="/images/vehicles/camaro.jpg" alt="Camaro performance upgrade">
          <p>Camaro Performance Kit</p>
        </div>

        <div class="upgrade-item">
          <img src="/images/vehicles/escalade.jpg" alt="Escalade luxury upgrade package">
          <p>Escalade Luxury Package</p>
        </div>

      </div>
    </div>

    <div class="reviews">
      <h2>DMC Delorean Reviews</h2>
      <ul>
        <li>"The coolest car I've ever driven!"</li>
        <li>"Turns heads everywhere."</li>
        <li>"Amazing futuristic design."</li>
        <li>"Feels like driving into the future."</li>
      </ul>

      <img 
        src="/images/vehicles/delorean.jpg" 
        alt="Silver DMC Delorean vehicle"
      >
    </div>

  </section>

</body>
</html>